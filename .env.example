# MathJobs Database Configuration
# ============================
# PostgreSQL (Production)
DATABASE_URL="postgresql://user:password@localhost:5432/mathjobs?schema=public"

# SQLite (Local Development - uncomment below and comment PostgreSQL above)
# DATABASE_URL="file:./dev.db"

# ============================================
# Auth.js Configuration
# ============================
# Generate random secret: openssl rand -base64 32
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Required for production deployment with certain OAuth providers
AUTH_TRUST_HOST=true

# Auth.js URL (required for production)
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (optional)
# AUTH_GITHUB_ID="your-github-client-id"
# AUTH_GITHUB_SECRET="your-github-client-secret"
# AUTH_GOOGLE_ID="your-google-client-id"
# AUTH_GOOGLE_SECRET="your-google-client-secret"