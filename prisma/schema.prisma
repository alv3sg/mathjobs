// MathJobs Database Schema
// Restaurant Staffing Platform - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USER MODEL
// ============================================
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  role      Role     @default(WAITER)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  applications Application[]
  reviews      Review[]
  preferences  UserPreference?
  accounts     Account[]
  sessions     Session[]
  postedJobs   Job[]           @relation("PostedJobs")
}

enum Role {
  ADMIN
  MANAGER
  WAITER
  BACKOFFICE
}

// ============================================
// JOB MODEL
// ============================================
model Job {
  id          String    @id @default(cuid())
  title       String
  description String
  location    String
  salary      Float
  shift       Shift
  status      JobStatus @default(OPEN)
  date        DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Restaurant Relation
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // User who posted this job
  postedById String?
  postedBy   User?   @relation("PostedJobs", fields: [postedById], references: [id])

  // Applications
  applications Application[]
}

enum Shift {
  MORNING
  AFTERNOON
  NIGHT
  FULL_TIME
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  CANCELLED
}

// ============================================
// RESTAURANT MODEL
// ============================================
model Restaurant {
  id        String   @id @default(cuid())
  name      String
  address   String
  city      String
  phone     String?
  email     String?
  website   String?
  image     String?
  rating    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  jobs    Job[]
  reviews Review[]
}

// ============================================
// APPLICATION MODEL
// ============================================
model Application {
  id        String    @id @default(cuid())
  status    AppStatus @default(PENDING)
  coverNote String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId  String
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

enum AppStatus {
  PENDING
  REVIEWING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

// ============================================
// REVIEW MODEL
// ============================================
model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  // Relations
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

// ============================================
// USER PREFERENCE MODEL
// ============================================
model UserPreference {
  id             String  @id @default(cuid())
  minSalary      Float?
  maxSalary      Float?
  preferredShift Shift?
  commuteRadius  Float?
  remoteOnly     Boolean @default(false)

  // Relation
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// NEXTAUTH MODELS (Required for Auth.js v5)
// ============================================
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
